# LlamaFleet environment — single systemd service
# Edit this file then: sudo systemctl restart llamafleet

# --- Required ---
API_AUTH_TOKEN=change-me
BRIDGE_AUTH_TOKEN=change-me

# Path to your llama-server binary (from llama.cpp releases or built from source)
LLAMA_SERVER_BIN=/usr/local/bin/llama-server

# This machine's IP address — used in proxy URLs shown in the dashboard
LLAMAFLEET_PUBLIC_HOST=127.0.0.1

# --- Service ports (defaults are fine for most setups) ---
PORT=8081
BRIDGE_PORT=8090

# Primary directory to scan for .gguf model files (shown in the model dropdown).
# Default: ~/.lmstudio/models
# LlamaFleet also auto-scans: ~/.ollama/models, ~/.cache/huggingface/hub, ~/unsloth_studio
#MODELS_DIR=/home/youruser/.lmstudio/models

# --- Data paths ---
STATE_FILE=/var/lib/llamafleet/api/state.json
SHARED_CONFIG_FILE=/var/lib/llamafleet/api/shared-config.yaml
DATA_ROOT=/var/lib/llamafleet/bridge
